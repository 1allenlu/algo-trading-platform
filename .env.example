# ─── Trading Platform — Environment Variables ─────────────────────────────────
# Copy this file: cp .env.example .env
# Never commit .env to version control!

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
POSTGRES_DB=trading_db

# Full URL used by the backend (PostgreSQL+asyncpg async driver)
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend ───────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# Allowed frontend origins for CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Alpaca Paper Trading (Phase 13 — real-time prices) ───────────────────────
# Get free paper-trading keys at: https://alpaca.markets
# Leave empty to use stale DB close prices (no Alpaca account required).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── JWT Authentication (Phase 17) ────────────────────────────────────────────
# Leave JWT_SECRET_KEY empty to DISABLE auth (all routes are public — dev mode).
# In production: generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
ADMIN_USERNAME=admin
# Generate a bcrypt password hash via:  POST /api/auth/hash  {"password": "yourpass"}
ADMIN_PASSWORD_HASH=
