# ─── Trading Platform — Environment Variables ─────────────────────────────────
# Copy this file: cp .env.example .env
# Never commit .env to version control!

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
POSTGRES_DB=trading_db

# Full URL used by the backend (PostgreSQL+asyncpg async driver)
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Backend ───────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# Allowed frontend origins for CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── Alpaca Paper Trading (Phase 5) ────────────────────────────────────────────
# Get keys at: https://app.alpaca.markets → Paper Trading
# ALPACA_API_KEY=your_api_key_here
# ALPACA_SECRET_KEY=your_secret_key_here
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── MLflow (Phase 2) ──────────────────────────────────────────────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000
